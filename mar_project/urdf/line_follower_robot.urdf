<?xml version="1.0"?>
<!--
  line_follower_robot.urdf
  A compact differential-drive robot that looks like a real line follower:
    - Flat rectangular chassis (orange)
    - Two large drive wheels
    - One front caster ball
    - Camera sensor mounted low at the front (angled down)
    - LiDAR on top
    - Visible sensor brackets
-->
<robot name="line_follower_robot">

  <!-- ═══════════════════════════════════════════════════════════════
       MATERIALS
  ══════════════════════════════════════════════════════════════════ -->
  <material name="orange">
    <color rgba="1.0 0.45 0.0 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.9 0.1 0.1 1.0"/>
  </material>
  <material name="blue_glass">
    <color rgba="0.2 0.4 1.0 0.7"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════════
       BASE FOOTPRINT (virtual link, required by nav)
  ══════════════════════════════════════════════════════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.05"/>   <!-- chassis sits 5 cm off ground -->
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════
       CHASSIS
  ══════════════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.26 0.18 0.05"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.26 0.18 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0" ixz="0"
               iyy="0.005" iyz="0"
               izz="0.007"/>
    </inertial>
  </link>

  <!-- ── Small raised electronics box on top ── -->
  <link name="top_deck">
    <visual>
      <geometry><box size="0.12 0.14 0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><box size="0.12 0.14 0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="top_deck_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="top_deck"/>
    <origin xyz="-0.02 0 0.0375"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════
       DRIVE WHEELS  (left & right)
  ══════════════════════════════════════════════════════════════════ -->
  <!-- LEFT WHEEL -->
  <link name="wheel_left">
    <visual>
      <geometry><cylinder radius="0.033" length="0.02"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.033" length="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00004" ixy="0" ixz="0"
               iyy="0.00004" iyz="0" izz="0.00006"/>
    </inertial>
  </link>
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_left"/>
    <origin xyz="0.0 0.105 -0.017" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- LEFT WHEEL HUB CAP (cosmetic) -->
  <link name="hub_left">
    <visual>
      <geometry><cylinder radius="0.016" length="0.005"/></geometry>
      <material name="silver"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="hub_left_joint" type="fixed">
    <parent link="wheel_left"/>
    <child  link="hub_left"/>
    <origin xyz="0 0 0.011"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="wheel_right">
    <visual>
      <geometry><cylinder radius="0.033" length="0.02"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.033" length="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00004" ixy="0" ixz="0"
               iyy="0.00004" iyz="0" izz="0.00006"/>
    </inertial>
  </link>
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_right"/>
    <origin xyz="0.0 -0.105 -0.017" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- RIGHT WHEEL HUB CAP (cosmetic) -->
  <link name="hub_right">
    <visual>
      <geometry><cylinder radius="0.016" length="0.005"/></geometry>
      <material name="silver"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="hub_right_joint" type="fixed">
    <parent link="wheel_right"/>
    <child  link="hub_right"/>
    <origin xyz="0 0 0.011"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════
       FRONT CASTER BALL
  ══════════════════════════════════════════════════════════════════ -->
  <link name="caster_front">
    <visual>
      <geometry><sphere radius="0.016"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.016"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0" izz="0.000003"/>
    </inertial>
  </link>
  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_front"/>
    <origin xyz="0.11 0 -0.034"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════
       CAMERA BRACKET  (small post at front)
  ══════════════════════════════════════════════════════════════════ -->
  <link name="camera_bracket">
    <visual>
      <geometry><box size="0.012 0.012 0.04"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="camera_bracket_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_bracket"/>
    <origin xyz="0.115 0 0.045"/>
  </joint>

  <!-- CAMERA BODY -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.03 0.05 0.025"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><box size="0.03 0.05 0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0" izz="0.000003"/>
    </inertial>
  </link>
  <!-- Angled 30° downward so it sees the ground in front -->
  <joint name="camera_joint" type="fixed">
    <parent link="camera_bracket"/>
    <child  link="camera_link"/>
    <origin xyz="0.02 0 0.02" rpy="0 0.523 0"/>   <!-- 0.523 rad = 30° -->
  </joint>

  <!-- CAMERA LENS (blue glass cylinder) -->
  <link name="camera_lens">
    <visual>
      <geometry><cylinder radius="0.009" length="0.008"/></geometry>
      <material name="blue_glass"/>
    </visual>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0"
               iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
  </link>
  <joint name="camera_lens_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_lens"/>
    <origin xyz="0.016 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- CAMERA OPTICAL FRAME (required by image pipeline) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════
       LIDAR (on top of electronics deck)
  ══════════════════════════════════════════════════════════════════ -->
  <link name="lidar_base">
    <visual>
      <geometry><cylinder radius="0.035" length="0.012"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.000005" ixy="0" ixz="0"
               iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>
  <joint name="lidar_base_joint" type="fixed">
    <parent link="top_deck"/>
    <child  link="lidar_base"/>
    <origin xyz="0 0 0.02"/>
  </joint>

  <link name="base_scan">
    <visual>
      <geometry><cylinder radius="0.025" length="0.015"/></geometry>
      <material name="red"/>
    </visual>
    <inertial>
      <mass value="0.04"/>
      <inertia ixx="0.000002" ixy="0" ixz="0"
               iyy="0.000002" iyz="0" izz="0.000002"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="lidar_base"/>
    <child  link="base_scan"/>
    <origin xyz="0 0 0.014"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════
       GAZEBO PLUGINS
  ══════════════════════════════════════════════════════════════════ -->

  <!-- Differential drive controller -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.21</wheel_separation>
      <wheel_diameter>0.066</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>

  <!-- Camera plugin -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="camera">
      <update_rate>15.0</update_rate>
      <always_on>true</always_on>
      <camera name="line_cam">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>5.0</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_optical_frame</frame_name>
        <image_topic_name>image_raw</image_topic_name>
        <camera_info_topic_name>camera_info</camera_info_topic_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- LiDAR plugin -->
  <gazebo reference="base_scan">
    <sensor type="ray" name="lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>3.5</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Caster wheel friction = 0 so it slides freely -->
  <gazebo reference="caster_front">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- Wheel friction — good grip -->
  <gazebo reference="wheel_left">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
  </gazebo>
  <gazebo reference="wheel_right">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
  </gazebo>

  <!-- Chassis colour in Gazebo -->
  <gazebo reference="base_link">
    <material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="top_deck">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="camera_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="camera_bracket">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="lidar_base">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="base_scan">
    <material>Gazebo/Red</material>
  </gazebo>

</robot>
